{
  "name": "gpt-workflow",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "check": "bunx tsc --noEmit && bun test && bun run mirror:check",
    "mirror:sync": "bun scripts/mirror.ts sync",
